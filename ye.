    Callback = function(Value)
        if not Value or Value == "" then return end
        
        local targetName = Value:match("%((.-)%)") or Value
        local targetPlayer = game.Players:FindFirstChild(targetName)
        
        if not targetPlayer then 
            Notify("NotFound", targetName)
            return 
        end
        
        if table.find(playersInLoop1V, Value) then
            local targetRank = GetPlayerRank(targetName)
            local myRank = GetPlayerRank(plr.Name)
            if myRank ~= Ranks.Owner and targetRank ~= Ranks.User and myRank <= targetRank then
                Notify("HigherRank", targetName)
                return
            end
            
            local idx = table.find(playersInLoop1V, Value)
            if idx then table.remove(playersInLoop1V, idx) end
            Notify("Removed", targetName)
        else
            local allowed, errorType = checkPermissions(targetPlayer)
            if not allowed then Notify(errorType, targetName); return end
            
            table.insert(playersInLoop1V, Value)
            Notify("Added", targetName)
        end
        
