    local function findMyPO()
        local myDisplayName = plr.DisplayName
        local myUserName = plr.Name
        local myPOIdentifier = string.format("[ %s ] ( @%s )", myDisplayName, myUserName)
        
        for _, obj in pairs(workspace:GetChildren()) do
