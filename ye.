                end
            end

            rs.CharacterEvents.Struggle:FireServer()
            rs.CharacterEvents.RagdollRemote:FireServer(hrp, 0)
            shouldKeepSit = true
            sitHoldTimer = 0.3
            hum.Sit = true
            hum.AutoRotate = true
            lastRagdollTime = now
            if hrp then
                setRagdollF(true)
            end
        end
    end)
