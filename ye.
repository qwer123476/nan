function loopPlayerBlobF()
    if typeof(UpdateCurrentBlobman) == "function" then pcall(UpdateCurrentBlobman) end
    
    local myHum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
    local seat = myHum and myHum.SeatPart
    if not (seat and seat.Parent and seat.Parent.Name == "CreatureBlobman") then return end
    
    local isRiding = true
    local processedHumanoids = {}

    local function processPlayer(player)
        if not player then return false end
        local character, hrp, head = safeGetCharacterParts(player)
        if not character or not hrp or not head then return false end
        if hrp.Massless == true and not isRiding then return false end
        
        local myChar = plr.Character
        local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHrp then return false end
        
        local originCF = myHrp.CFrame
        local tpRunning = true
        local CF = originCF

        task.spawn(function()
            while tpRunning and blobLoopT do
                if typeof(TP) == "function" then
                    local ok, cf = pcall(TP, player)
                    if ok and cf then CF = cf end
                end
                task.wait()
            end
        end)

        while blobLoopT and player.Parent and character.Parent do
            if head and head.Parent then
                pcall(function()
                    rs.GrabEvents.SetNetworkOwner:FireServer(head, head.CFrame)
                end)
                local ownerTag = head:FindFirstChild("PartOwner")
                if ownerTag and ownerTag:IsA("StringValue") and ownerTag.Value == plr.Name then break end
            else
                break
            end
            task.wait()
        end
        
        tpRunning = false

        pcall(function()
            local targetNames = { "NinjaKunai", "NinjaShuriken", "NinjaKatana", "ToolCleaver", "ToolDiggingForkRusty", "ToolPencil", "ToolPickaxe" }
            for _, child in ipairs(workspace:GetChildren()) do
                if child:IsA("Folder") and child.Name:match("SpawnedInToys$") and child.Name ~= (plr.Name .. "SpawnedInToys") then
                    for _, item in ipairs(child:GetChildren()) do
                        if table.find(targetNames, item.Name) and item:FindFirstChild("StickyPart") then
                            local sticky = item.StickyPart
                            local weld = sticky:FindFirstChild("StickyWeld")
                            if weld and weld:IsA("WeldConstraint") and weld.Part1 then
                                local targetParts = {
                                    character:FindFirstChild("Head"),
                                    character:FindFirstChild("Torso"),
                                    character:FindFirstChild("Left Arm"),
                                    character:FindFirstChild("Left Leg"),
                                    character:FindFirstChild("Right Arm"),
                                    character:FindFirstChild("Right Leg"),
                                    hrp:FindFirstChild("RagdollTouchedHitbox"),
                                    hrp:FindFirstChild("FirePlayerPart"),
                                }
                                if table.find(targetParts, weld.Part1) then
                                    local basePart = item.PrimaryPart or sticky
                                    if basePart and hrp and hrp.Parent and (basePart.Position - hrp.Position).Magnitude <= 10 then
                                        rs.GrabEvents.SetNetworkOwner:FireServer(sticky, sticky.CFrame)
                                        sticky.CFrame = CFrame.new(0, 9999, 0)
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end)

        pcall(function()
            if head and head.Parent then
                rs.GrabEvents.DestroyGrabLine:FireServer(head, head.CFrame)
            end
            if hrp and hrp.Parent and myHrp and myHrp.Parent then
                hrp.CFrame = CFrame.new(myHrp.CFrame.X, myHrp.CFrame.Y + 50, myHrp.CFrame.Z)
                myHrp.CFrame = hrp.CFrame
            end
            if typeof(BlobMassless) == "function" and hrp and hrp.Parent then
                BlobMassless(currentBlobS, hrp, "Right")
            end
            if originCF and typeof(BACK) == "function" then 
                BACK(originCF) 
            end
        end)
        return true
    end

    task.spawn(function()
        while blobLoopT do
            for _, name in ipairs(playersInLoop2V) do
                if not blobLoopT then break end
                local player = game.Players:FindFirstChild(name)
                if not player then continue end
                if (PPs and PPs:FindFirstChild(name)) or (inv and inv:FindFirstChild(name)) then continue end
                
                local character = player.Character
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp and hrp:IsA("BasePart") and hrp.Massless and not isRiding then continue end
                if humanoid and humanoid.Health > 0 then
                    if processedHumanoids[player] ~= humanoid then
                        local success = processPlayer(player)
                        if success then processedHumanoids[player] = humanoid end
                    end
                else
                    processedHumanoids[player] = nil
                end
                task.wait(0.05)
            end
            task.wait(0.3)
        end
    end)
end

function loopPlayerBlobF3()
    if typeof(UpdateCurrentBlobman) == "function" then pcall(UpdateCurrentBlobman) end

    local myHum = plr.Character and plr.Character:FindFirstChildOfClass("Humanoid")
    local seat = myHum and myHum.SeatPart

    if not (seat and seat.Parent and seat.Parent.Name == "CreatureBlobman") then
        return
    end

    local runningTasks = {}

    local function waitForRespawn(player)
        while blobLoopT3 and player.Parent do
            local char = player.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                return char
            end
            task.wait(0.01)
        end
    end

    task.spawn(function()
        while blobLoopT3 do
            for _, name in ipairs(playersInLoop2V) do
                if not blobLoopT3 then break end

                local player = game.Players:FindFirstChild(name)
                if not player then continue end
                if PPs and PPs:FindFirstChild(name) then continue end
                if runningTasks[player] then continue end

                runningTasks[player] = task.spawn(function()
                    local beforeTP

                    while blobLoopT3 and player.Parent do
                        local myChar = plr.Character
                        local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                        if not myHrp then task.wait(0.1) continue end

                        if not beforeTP then
                            beforeTP = myHrp.CFrame
                        end

                        local char = player.Character
                        local hum = char and char:FindFirstChildOfClass("Humanoid")

                        if hum and hum.Health <= 0 then
                            if beforeTP and typeof(BACK) == "function" then
                                pcall(BACK, beforeTP)
                            end

                            waitForRespawn(player)

                            local myChar2 = plr.Character
                            local myHrp2 = myChar2 and myChar2:FindFirstChild("HumanoidRootPart")
                            if myHrp2 then
                                beforeTP = myHrp2.CFrame
                            end
                            continue
                        end

                        if not hum then
                            task.wait(0.01)
                            continue
                        end

                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        if not hrp then task.wait(0.01) continue end

                        local distance = (myHrp.Position - hrp.Position).Magnitude
                        if distance > 30 then
                            if typeof(TP) == "function" then
                                pcall(TP, player)
                            end
                            task.wait(0.01)
                            continue
                        end

                        pcall(function()
                            hum.BreakJointsOnDeath = false
                            hum.WalkSpeed = 0
                            hum.JumpPower = 0

                            if hum.SeatPart == nil then
                                hum.RigType = Enum.HumanoidRigType.R15
                                hum.RigType = Enum.HumanoidRigType.R6
                                hum.RigType = Enum.HumanoidRigType.R15
                            end
                        end)

                        for i = 1, 3 do
                            if not blobLoopT3 or not hrp.Parent then break end
                            if typeof(BlobGrab) == "function" and typeof(BlobRelease) == "function" then
                                pcall(BlobGrab, currentBlobS, hrp, "Right")
                                pcall(BlobRelease, currentBlobS, hrp, "Right")
                            end
                            task.wait()
                        end
                        task.wait()
                    end

                    if beforeTP and typeof(BACK) == "function" then
                        pcall(BACK, beforeTP)
                    end
                    runningTasks[player] = nil
                end)
                task.wait()
            end
            task.wait()
        end

        for _, t in pairs(runningTasks) do
            if typeof(t) == "thread" then
                task.cancel(t)
            end
        end
        runningTasks = {}
    end)
end

