local function GetCurrentPlayers()
    local tbl = {}
    for _, p in ipairs(game.Players:GetPlayers()) do
        if p ~= plr then
            table.insert(tbl, string.format("%s (%s)", p.DisplayName, p.Name))
        end
    end
    return tbl
end

