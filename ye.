hasDetectedFirstTime = false
function AntiPCLDF()
    local targetValueName = "[ " .. plr.DisplayName .. " ] ( @" .. plr.Name .. " )"
    
    task.spawn(function()
        while AntiPCLDT do
            task.wait()
            if not AntiPCLDT then break end
            
            if not hasDetectedFirstTime then
                for _, item in ipairs(workspace:GetChildren()) do
                    if item.Name == "PlayerCharacterLocationDetector" then
                        for _, child in ipairs(item:GetChildren()) do
                            if child:IsA("BoolValue") and child.Name == targetValueName then
                                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChildOfClass("Humanoid") then
                                    plr.Character.HumanoidRootPart.CFrame = CFrame.new(0, 999999, 0)
                                    task.wait(0.1)
                                    plr.Character:FindFirstChildOfClass("Humanoid").Health = 0
                                    hasDetectedFirstTime = true
                                end
                            end
                        end
                    end
                end
            else
                local character = plr.Character or plr.CharacterAdded:Wait()
                local humanoid = character:WaitForChild("Humanoid")
                
                local diedConn
                diedConn = humanoid.Died:Connect(function()
                    if AntiPCLDT and hasDetectedFirstTime then
                        local torso = character:FindFirstChild("Torso")
                        local CF = torso and torso.CFrame or CFrame.new(0,0,0)
                        
                        local nextChar = plr.CharacterAdded:Wait()
                        local nextHum = nextChar:WaitForChild("Humanoid")
                        nextHum:ChangeState(Enum.HumanoidStateType.Dead)
                        
                        local nextTorso = nextChar:WaitForChild("Torso")
                        if nextTorso then nextTorso.CFrame = CF end
                        task.wait(5)
                    end
                end)
                
                plr.CharacterAdded:Wait()
                if diedConn then diedConn:Disconnect() end
            end
        end
    end)
end

